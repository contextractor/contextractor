{
  "name": "contextractor",
  "version": "0.2.0",
  "description": "Extract web content from URLs with configurable extraction options",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/contextractor/contextractor.git"
  },
  "homepage": "https://github.com/contextractor/contextractor",
